{
  "name": "motamayez-admin",
  "version": "2.0.0",
  "description": "Admin Dashboard for Motamayez Activation System",
  "main": "server.js",
  "scripts": {
    "build": "npm run build:admin",
    "build:admin": "esbuild src/AdminApp.jsx --bundle --outfile=public/js/admin.bundle.js --format=iife --global-name=MotamayezAdmin --define:process.env.NODE_ENV=\\\"production\\\" --minify",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint ."
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "mongoose": "^8.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
